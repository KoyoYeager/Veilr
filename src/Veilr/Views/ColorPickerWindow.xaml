<Window x:Class="Veilr.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Eyedropper button -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="LblEyedropper" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
            <Button x:Name="BtnEyedrop" Height="32" Click="BtnEyedrop_Click"/>
        </StackPanel>

        <!-- Zoom preview -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,12"
                Width="200" Height="200" HorizontalAlignment="Center">
            <Image x:Name="ZoomPreview" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Border>

        <!-- Picked color preview -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock x:Name="LblPickedColor" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
            <Border Width="200" Height="40" CornerRadius="4" BorderThickness="1" BorderBrush="Gray"
                    HorizontalAlignment="Left">
                <Border.Background>
                    <SolidColorBrush x:Name="PickedColorBrush" Color="Red"/>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Color values -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="HEX:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock x:Name="TxtHex" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" FontSize="13"/>
            <TextBlock Text="R:" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBlock x:Name="TxtR" Grid.Column="3" VerticalAlignment="Center"/>
            <TextBlock Text="G:" Grid.Column="4" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBlock x:Name="TxtG" Grid.Column="5" VerticalAlignment="Center"/>
            <TextBlock Text="B:" Grid.Column="6" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBlock x:Name="TxtB" Grid.Column="7" VerticalAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="H:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock x:Name="TxtH" Grid.Column="1" VerticalAlignment="Center"/>
            <TextBlock Text="S:" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBlock x:Name="TxtS" Grid.Column="3" VerticalAlignment="Center"/>
            <TextBlock Text="V:" Grid.Column="4" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBlock x:Name="TxtV" Grid.Column="5" VerticalAlignment="Center"/>
        </Grid>

        <!-- Manual hex input -->
        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <TextBlock x:Name="LblManualInput" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="HEX:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtHexInput" Width="100" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                <Button x:Name="BtnApplyHex" Margin="8,0,0,0" Padding="12,4" Click="BtnApplyHex_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="6" Margin="0,8,0,0">
            <Button x:Name="BtnUseColor" Height="32" Margin="0,0,0,8" Click="BtnUseColor_Click"/>
            <Button x:Name="BtnCancelPicker" Height="32" Click="BtnCancelPicker_Click"/>
        </StackPanel>
    </Grid>
</Window>
