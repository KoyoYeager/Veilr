<Window x:Class="Veilr.Views.SheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="420" Height="240"
        MinWidth="300" MinHeight="100"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="8" ClipToBounds="True"
            Background="{Binding SheetBrush}"
            BorderThickness="{Binding WindowBorderThickness}"
            BorderBrush="{Binding WindowBorderBrush}"
            MouseLeftButtonDown="DragBar_MouseDown"
            MouseMove="DragBar_MouseMove"
            MouseLeftButtonUp="DragBar_MouseUp">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- Processed image covers entire window (both modes) -->
            <Image x:Name="ProcessedImage" Grid.Row="0" Grid.RowSpan="3"
                   Source="{Binding ProcessedImageSource}"
                   Stretch="Fill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Drag bar -->
            <Border Grid.Row="0" Background="{Binding BarBackground}">
                <Grid TextElement.Foreground="{Binding BarForeground}">
                    <TextBlock Text="{Binding ModeLabel}" Opacity="0.8"
                               FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <Button Content="✕" Click="BtnClose_Click" Style="{StaticResource ToolbarButton}"
                            Width="28" Height="22" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="2" Background="{Binding BarBackground}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="4,0"
                            TextElement.Foreground="{Binding BarForeground}">
                    <Button x:Name="BtnMode" Content="{Binding ModeSwitchLabel}"
                            Click="BtnMode_Click" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="{Binding FullScreenLabel}" Click="BtnFullScreen_Click"
                            Style="{StaticResource ToolbarButton}"/>
                    <Button Content="{Binding ExportLabel}" Click="BtnExport_Click"
                            Style="{StaticResource ToolbarButton}"/>
                    <Button Content="{Binding SettingsLabel}" Click="BtnSettings_Click"
                            Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
