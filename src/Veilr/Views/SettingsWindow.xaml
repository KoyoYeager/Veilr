<Window x:Class="Veilr.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="16,16,16,0">

            <!-- Tab 1: Color Settings -->
            <TabItem x:Name="Tab1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <TextBlock x:Name="LblSheetColor" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="40" Height="28" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="Gray"
                                    Background="{Binding ColorPreview}" Margin="0,0,8,0"/>
                            <TextBox Width="80" Text="{Binding HexColor, UpdateSourceTrigger=LostFocus}"
                                     VerticalContentAlignment="Center" FontFamily="Consolas"/>
                            <Button x:Name="BtnChange" Margin="8,0,0,0" Padding="12,4"
                                    Click="BtnPickColor_Click"/>
                            <Button x:Name="BtnEyedropper" Margin="4,0,0,0" Padding="12,4"
                                    Click="BtnEyedropper_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="LblOpacity" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0.1" Maximum="1.0"
                                    Value="{Binding Opacity}" VerticalAlignment="Center"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <Binding Path="OpacityPercent" StringFormat="{}{0}%"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>

                        <!-- Erase algorithm -->
                        <TextBlock x:Name="LblAlgorithm" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <RadioButton IsChecked="{Binding IsChromaKey}" Margin="0,0,0,2">
                            <StackPanel>
                                <TextBlock Text="Chroma Key" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LblChromaKeyDesc" FontSize="11" Foreground="Gray"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsLabMask}" Margin="0,8,0,2">
                            <StackPanel>
                                <TextBlock Text="Lab Mask" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LblLabMaskDesc" FontSize="11" Foreground="Gray"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsYCbCr}" Margin="0,8,0,16">
                            <StackPanel>
                                <TextBlock Text="YCbCr" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LblYCbCrDesc" FontSize="11" Foreground="Gray"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <TextBlock x:Name="LblTolerance" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="LblToleranceDesc" FontSize="11" Foreground="Gray" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblStrict" VerticalAlignment="Center" FontSize="11" Foreground="Gray"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding Tolerance}" VerticalAlignment="Center"
                                    TickFrequency="5" IsSnapToTickEnabled="True"/>
                            <TextBlock x:Name="LblFlexible" VerticalAlignment="Center"
                                       HorizontalAlignment="Right" FontSize="11" Foreground="Gray"/>
                        </Grid>
                        <TextBlock HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="Tolerance" StringFormat="{}{0}"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Behavior -->
            <TabItem x:Name="Tab2">
                <StackPanel Margin="12">
                    <TextBlock x:Name="LblEraseSettings" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblUpdateRate" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="100" Maximum="500"
                                Value="{Binding UpdateIntervalMs}" VerticalAlignment="Center"
                                TickFrequency="50" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock.Text>
                                <Binding Path="UpdateIntervalMs" StringFormat="{}{0}ms"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <TextBlock x:Name="LblUpdateRateDesc" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 3: Hotkey -->
            <TabItem x:Name="Tab3">
                <StackPanel Margin="12">
                    <TextBlock x:Name="LblHotkeySettings" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblToggleSheet" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding HotkeyToggleSheet}"
                                 VerticalContentAlignment="Center" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="13"/>
                    </Grid>
                    <TextBlock x:Name="LblHotkeyNote" FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 4: Appearance -->
            <TabItem x:Name="Tab4">
                <StackPanel Margin="12">
                    <TextBlock Text="言語 / Language" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>
                    <ComboBox Width="150" HorizontalAlignment="Left"
                              SelectedIndex="{Binding LanguageIndex}">
                        <ComboBoxItem Content="日本語"/>
                        <ComboBoxItem Content="English"/>
                    </ComboBox>
                    <TextBlock x:Name="LblLanguageNote" FontSize="11" Margin="0,8,0,0" Foreground="Gray"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,16,0">
            <Button x:Name="BtnApply" Width="80" Height="30" Margin="0,0,8,0" Click="BtnApply_Click"/>
            <Button x:Name="BtnCancelBtn" Width="80" Height="30" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="OK" Width="80" Height="30" Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>
